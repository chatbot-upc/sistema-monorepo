# Reverse proxy del chatbot UPC.
# - Si DOMAIN esta definido (ej. crm.tudominio.com) -> HTTPS automatico (Let's Encrypt).
# - Si DOMAIN esta vacio -> escucha en :80 (acceso por la IP del EIP, sin TLS).
#
# Rutas:
#   /api/*  y  /health  -> FastAPI (incluye el webhook de WhatsApp en /api/v1/...)
#   /docs/*             -> FastAPI (PDFs públicos: /docs/{id}/{slug}.pdf, proxy al S3)
#   resto               -> Next.js (panel admin)

{$DOMAIN::80} {
	encode gzip zstd

	@api path /api/* /health /docs/*
	handle @api {
		reverse_proxy api:8000
	}

	handle {
		reverse_proxy web:3000
	}
}
