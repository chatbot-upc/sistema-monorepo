# Reverse proxy del chatbot UPC.
# - Si DOMAIN esta definido (ej. crm.tudominio.com) -> HTTPS automatico (Let's Encrypt).
# - Si DOMAIN esta vacio -> escucha en :80 (acceso por la IP del EIP, sin TLS).
#
# Rutas:
#   /api/v1/*  /api/webhooks/*  /health  /docs/*  -> FastAPI
#   resto (incl. /api/auth/* de Auth.js)          -> Next.js (panel admin)
# OJO: NO enrutar todo /api/* a FastAPI — Next.js (Auth.js) usa /api/auth/* para
# el login; si se lo mandas a FastAPI, devuelve 404 {"detail":"Not Found"}.

{$DOMAIN::80} {
	encode gzip zstd

	@api path /api/v1/* /api/webhooks/* /health /docs/*
	handle @api {
		reverse_proxy api:8000
	}

	handle {
		reverse_proxy web:3000
	}
}
