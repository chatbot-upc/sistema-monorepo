# Application
ENV=local
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000
# Base pública (dominio con HTTPS) para los links de PDFs que comparte el bot.
# Vacío = no adjunta links. En prod: https://remiai.tech
PUBLIC_BASE_URL=

# Database
DATABASE_URL=postgresql+asyncpg://chatbot:chatbot@localhost:5433/chatbot

# Redis
REDIS_URL=redis://localhost:6380/0
CELERY_BROKER_URL=redis://localhost:6380/1
CELERY_RESULT_BACKEND=redis://localhost:6380/2

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Storage (Fase 3: filesystem local; Fase 5: backend S3)
LOCAL_UPLOADS_DIR=./uploads

# RAG tuning
# Para docs normales. Las MALLAS no usan esto: se chunkean por CICLO
# (splitter estructural en rag/splitter.py) → 1 chunk por ciclo, sin mezclar.
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=5
RAG_FETCH_K=20

# LangSmith (opcional para debugging)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=chatbot-upc

# Meta WhatsApp Cloud API
META_VERIFY_TOKEN=
META_APP_SECRET=
META_PHONE_NUMBER_ID=
META_ACCESS_TOKEN=
META_GRAPH_API_VERSION=v21.0

# AWS
AWS_REGION=us-east-1
# En prod, el bucket lo crea el CDK con nombre determinista:
# chatbot-upc-docs-<account_id> (ver output DocsBucketName del FrugalStack).
AWS_S3_BUCKET=chatbot-upc-docs
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_REGION=us-east-1

# Admin del CRM a sembrar en la BD (debe coincidir con el email del user de
# Cognito). El servicio `migrate` lo crea en cada deploy. Vacío = no siembra.
ADMIN_EMAIL=
ADMIN_NAME=

# Firebase Cloud Messaging — backend (web push notifications, SW-33)
# Extraer del JSON de service account (Firebase Console → Settings → Service accounts):
#   project_id      → FIREBASE_PROJECT_ID
#   client_email    → FIREBASE_CLIENT_EMAIL
#   private_key_id  → FIREBASE_PRIVATE_KEY_ID
#   private_key     → FIREBASE_PRIVATE_KEY (con saltos de línea escapados \\n, una sola línea)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY=

# Frontend (apps/web)
# AUTH_SECRET: REQUERIDO por Auth.js v5 (cifra sesión/JWT). Sin él, el login da
# "There is a problem with the server configuration". Genera uno con:
#   openssl rand -base64 32
AUTH_SECRET=
# API_URL: lo usa el SERVIDOR de Next (server actions: login, /me, devices,
# ws-ticket) en RUNTIME. En prod (docker compose) el web llega a la API por el
# nombre de servicio interno → API_URL=http://api:8000. En local: localhost:8000.
API_URL=http://localhost:8000
# NEXT_PUBLIC_*: se HORNEAN en el build de la imagen web (no en runtime). En prod
# se pasan como build-args en build-images.yml (ver vars del repo en GitHub).
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_COGNITO_USER_POOL_ID=
NEXT_PUBLIC_COGNITO_CLIENT_ID=
NEXT_PUBLIC_COGNITO_REGION=us-east-1

# Frontend Firebase web app config (Project Settings → General → Your apps → Web)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# VAPID public key (Project Settings → Cloud Messaging → Web Push certificates)
NEXT_PUBLIC_FIREBASE_VAPID_KEY=
